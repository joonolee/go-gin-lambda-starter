# 스테이지별로 .env.dev / .env.prod 로 복사해서 사용
# Serverless Framework가 --stage 값에 따라 자동 로드한다

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=app_dev
DB_SSLMODE=disable

# Firebase (Authorization 헤더 검증용)
FIREBASE_PROJECT_ID=your-firebase-project-id

# (선택) Lambda VPC 배치용 — prod에서 RDS Private Subnet에 둘 때 필요
# VPC_SG_ID=sg-xxxxxxxx
# VPC_SUBNET_1=subnet-xxxxxxxx
# VPC_SUBNET_2=subnet-xxxxxxxx
# VPC_SUBNET_3=subnet-xxxxxxxx

# (선택) serverless-domain-manager 사용 시
# CUSTOM_DOMAIN=api.example.com
# ACM_CERT_ARN=arn:aws:acm:ap-northeast-2:000000000000:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
